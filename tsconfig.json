{
    "compilerOptions": {
        "target": "ES2024",
        "module": "ESNext",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.d.ts",
        "src/**/*.svelte"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}