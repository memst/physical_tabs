{
    "compilerOptions": {
        "target": "ES6",
        "module": "ESNext",
        "outDir": "dist",
        "rootDir": "ts",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "ts/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}