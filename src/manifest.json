{
  "manifest_version": 3,
  "name": "Physical Tabs",
  "version": "1.0",
  "description": "Save and restore your open tabs to and from a file.",
  "permissions": [
    "tabs",
    "downloads",
    "windows",
    "storage",
    "favicon"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Physical Tabs"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "_favicon/*"
      ],
      "matches": [
        "<all_urls>"
      ],
      "extension_ids": [
        "*"
      ]
    }
  ]
}
